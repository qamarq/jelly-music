<?xml version="1.0" encoding="utf-8"?>
<about-screen>
    <!--
      ENTRY
      - title: visible title shown in the About screen.
      - description: visible supporting copy shown under the title.
      - logoUrl: optional image link for the first header row.
        Use @drawable/your_logo for bundled app artwork, or paste a content://,
        file://, android.resource://, or https:// image link here.

      LINK
      - label: visible button text.
      - url: destination opened when the pill is tapped.
      Icon is chosen automatically from the domain:
      instagram -> Instagram icon
      x.com / twitter.com -> X icon
      github.com -> GitHub icon
      ko-fi.com / kofi.com -> Ko-fi icon
      anything else -> globe icon
    -->
    <entry
        title="qamarq"
        description="Maintainer of this JellyMusic fork. Add your own bio here!">
        <link
            label="JellyMusic on GitHub"
            url="https://github.com/qamarq/jelly-music" />
    </entry>

    <entry
        title="Droid Beauty"
        description="Beautifully designed widgets and themes for Android to make your homescreen stunning. Also the original creator of Elovaire Music, the project this app was forked from."
        logoUrl="https://raw.githubusercontent.com/user774820/logoimages/refs/heads/main/DroidBeautyLogo.png">
        <link
            label="Instagram"
            url="https://instagram.com/droidbeauty" />
        <link
            label="Twitter"
            url="https://x.com/droidbeauty" />
        <link
            label="Play Store"
            url="https://play.google.com/store/apps/dev?id=7791472155222642322" />
        <link
            label="Ko-fi"
            url="https://ko-fi.com/droidbeauty" />
        <link
            label="Elovaire Music (original repo)"
            url="https://github.com/droidbeauty/elovaire-music" />
    </entry>

    <entry
        title="Resources"
        description="JellyMusic is built with modern open-source Android components that shape experience of the app. Thanks to everyone creating resources such as Media3 playback, Jetpack Compose framework or Lucide icons">
        <link
            label="Android Developer"
            url="https://developer.android.com" />
        <link
            label="Lucide icons"
            url="https://lucide.dev/" />
    </entry>
</about-screen>
